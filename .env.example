# From https://developer.spotify.com/dashboard — your app's Client ID and Secret
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Must match exactly what you register under "Redirect URIs" in the dashboard
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Optional: genre/mood tags from Last.fm (https://www.last.fm/api/account/create)
LASTFM_API_KEY=

# Required for generate_playlist_plan.py (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
